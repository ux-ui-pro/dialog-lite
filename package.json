{
  "name": "dialog-lite",
  "version": "3.0.0",
  "description": "DialogLite is designed to control a dialog box (modal window) on a web page, providing the functionality to open, close and apply custom styles through a simple interface.",
  "type": "module",
  "author": "ux-ui.pro",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ux-ui-pro/dialog-lite.git"
  },
  "bugs": {
    "url": "https://github.com/ux-ui-pro/dialog-lite/issues"
  },
  "homepage": "https://github.com/ux-ui-pro/dialog-lite",
  "sideEffects": [
    "*.css"
  ],
  "packageManager": "npm@10.9.3",
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsdown",
    "verify": "npm run lint && npm run typecheck && npm run test:unit && npm run build && npm run test:smoke && npm run pack:check",
    "lint": "biome check src tests tsdown.config.ts vitest.config.ts",
    "lint:fix": "biome check --write src tests tsdown.config.ts vitest.config.ts",
    "format": "biome format --write src tests tsdown.config.ts vitest.config.ts",
    "test:smoke": "node --test \"tests/**/*.js\"",
    "test:unit": "vitest-runner run src",
    "test": "npm run test:unit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pack:check": "npm pack --dry-run && publint && attw --pack . --profile node16 --exclude-entrypoints dialog-lite.css",
    "prepublishOnly": "npm run clean && npm run verify"
  },
  "source": "src/index.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/dialog-lite.css",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./vue": {
      "import": {
        "types": "./dist/vue.d.ts",
        "default": "./dist/vue.js"
      },
      "require": {
        "types": "./dist/vue.d.cts",
        "default": "./dist/vue.cjs"
      }
    },
    "./dialog-lite.css": {
      "default": "./dist/dialog-lite.css"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@biomejs/biome": "2.4.16",
    "@tsdown/css": "^0.22.3",
    "@types/node": "25.9.2",
    "@ux-ui/biome-config": "^0.1.0",
    "@ux-ui/tsconfig-base": "^0.1.0",
    "@ux-ui/tsdown-config": "^0.1.0",
    "@ux-ui/vitest-runner": "^0.1.0",
    "@vue/compiler-dom": "3.5.35",
    "@vue/test-utils": "2.4.11",
    "jsdom": "29.1.1",
    "publint": "^0.3.21",
    "rimraf": "6.1.3",
    "sass-embedded": "^1.100.0",
    "tsdown": "0.22.3",
    "typescript": "6.0.3",
    "vitest": "^4.1.9",
    "vue": "3.5.35"
  },
  "keywords": [
    "dialog-lite",
    "dialog",
    "modal",
    "component",
    "ui",
    "overlay",
    "popup",
    "a11y",
    "keyboard",
    "accessibility",
    "dom",
    "javascript",
    "typescript"
  ]
}
