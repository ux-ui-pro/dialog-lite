{
  "name": "dialog-lite",
  "version": "2.1.0",
  "description": "DialogLite is designed to control a dialog box (modal window) on a web page, providing the functionality to open, close and apply custom styles through a simple interface.",
  "type": "module",
  "author": "ux-ui.pro",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ux-ui-pro/dialog-lite.git"
  },
  "bugs": {
    "url": "https://github.com/ux-ui-pro/dialog-lite/issues"
  },
  "homepage": "https://github.com/ux-ui-pro/dialog-lite",
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "vite build",
    "verify": "yarn lint && yarn typecheck && yarn test",
    "lint": "biome check src tests vite.config.ts",
    "lint:fix": "biome check --write src tests vite.config.ts",
    "format": "biome format --write src",
    "test:smoke": "yarn build && node --test tests/*.test.js",
    "test": "vitest run src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "yarn clean && yarn verify && yarn test:smoke && yarn pack:check"
  },
  "source": "src/index.ts",
  "main": "dist/index.cjs",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "style": "dist/dialog-lite.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.es.js",
      "require": "./dist/vue.cjs"
    },
    "./dialog-lite.css": "./dist/dialog-lite.css",
    "./dist/*": "./dist/*"
  },
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/node": "25.9.2",
    "@vue/compiler-dom": "3.5.35",
    "@vue/test-utils": "2.4.11",
    "jsdom": "29.1.1",
    "lightningcss": "1.32.0",
    "rimraf": "6.1.3",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vite-plugin-dts": "5.0.2",
    "vitest": "4.1.8",
    "vue": "3.5.35"
  },
  "keywords": [
    "dialog-lite",
    "dialog",
    "modal",
    "component",
    "ui",
    "overlay",
    "popup",
    "a11y",
    "keyboard",
    "accessibility",
    "dom",
    "javascript",
    "typescript"
  ]
}
